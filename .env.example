# ─────────────────────────────────────────────────────────────────
# FlowPDPA — Environment Variables
# Copy this file to .env and fill in the values.
# Without these set, the app runs in LOCAL/DEMO mode (localStorage only).
# ─────────────────────────────────────────────────────────────────

# ── Odoo Connection (required for all backend features) ──────────
VITE_ODOO_URL=https://yourcompany.odoo.com
VITE_ODOO_DB=your_database_name
VITE_ODOO_API_KEY=your_api_key_here

# ── Helpdesk (Odoo Helpdesk module) ──────────────────────────────
# Get this from: Odoo → Helpdesk → Configuration → Teams → (open team) → check URL for ID
VITE_ODOO_TEAM_ID=1

# ─────────────────────────────────────────────────────────────────
# BACKEND SETUP CHECKLIST (for the backend/Odoo developer)
# ─────────────────────────────────────────────────────────────────
#
# 1. ODOO MODULES TO INSTALL
#    - helpdesk        (for ticket submission & tracking)
#    - contacts / crm  (for res.partner — user profiles)
#
# 2. CREATE AN API KEY
#    Odoo → Settings → Technical → API Keys → New
#    Paste the key as VITE_ODOO_API_KEY above.
#
# 3. CONFIGURE CORS (critical — frontend will be blocked without this)
#    Odoo → Settings → Technical → System Parameters
#    Add key:   web.cors.origins
#    Value:     https://your-frontend-domain.com
#    (for local dev add: http://localhost:5173)
#
# 4. GET HELPDESK TEAM ID
#    Odoo → Helpdesk → Configuration → Teams
#    Open your team → check the URL: /odoo/helpdesk/1 → ID is 1
#    Set as VITE_ODOO_TEAM_ID above.
#
# 5. GET TICKET TYPE IDs  ← IMPORTANT: update src/pages/Helpdesk.tsx
#    Odoo → Helpdesk → Configuration → Ticket Types
#    Open each type → check URL for numeric ID
#    Then update the ticketTypes array in src/pages/Helpdesk.tsx:
#
#    export const ticketTypes = [
#      { id: null, label: 'ไม่ระบุ' },
#      { id: <ID>, label: 'Question / คำถาม' },
#      { id: <ID>, label: 'Issue / ปัญหาการใช้งาน' },
#      { id: <ID>, label: 'Feature Request / ขอฟีเจอร์' },
#      { id: <ID>, label: 'Other / อื่นๆ' },
#    ]
#
# 6. CREATE HELPDESK TAGS (maps to category cards in the UI)
#    Odoo → Helpdesk → Configuration → Tags → create these tags:
#    - technical
#    - billing
#    - policy
#    - account
#    - pdpa
#    - other
#    (tag names must match the id values in src/pages/Helpdesk.tsx categories array)
#
# 7. TEST THE CONNECTION
#    Set the env vars above → restart dev server (npm run dev)
#    → Submit a test ticket on /helpdesk
#    → Should appear in Odoo → Helpdesk → Tickets
#
# ─────────────────────────────────────────────────────────────────
# WHAT EACH ENV VAR UNLOCKS
# ─────────────────────────────────────────────────────────────────
#
# VITE_ODOO_URL + VITE_ODOO_DB + VITE_ODOO_API_KEY:
#   ✅ User profile sync     → Dashboard → Account → saves to res.partner
#   ✅ Helpdesk tickets      → /helpdesk submit → creates helpdesk.ticket
#   ✅ Ticket tracking       → /helpdesk/track → reads live status from Odoo
#   ✅ Cookie consent log    → Accept cookies → note posted to res.partner chatter
#
# + VITE_ODOO_TEAM_ID:
#   ✅ Tickets go to the correct helpdesk team in Odoo
#
# ─────────────────────────────────────────────────────────────────
# WHAT STILL NEEDS CUSTOM BACKEND WORK (not solved by Odoo alone)
# ─────────────────────────────────────────────────────────────────
#
# ❌ Authentication — login/register currently uses localStorage only.
#    For production: integrate Odoo portal auth (/web/session/authenticate)
#    or add a separate auth service (e.g. Supabase, Firebase, custom JWT).
#
# ❌ Policy storage — generated policies are not persisted to any database.
#    For production: store in Odoo (custom model) or a separate DB/storage.
#
# ─────────────────────────────────────────────────────────────────
